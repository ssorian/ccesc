generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  lastName      String?
  email         String       @unique
  emailVerified Boolean
  image         String?
  role          UserRole     @default(STUDENT)
  institutionId String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  institution   Institution?
  sessions      Session[]
  student       Student?
  teacher       Teacher?

  @@index([institutionId])
  @@index([role])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Institution {
  id                     String                      @id @default(cuid())
  userId                 String                      @unique
  slug                   String                      @unique
  address                String?
  enableGlobalEvaluation Boolean                     @default(false)
  globalEvaluationWeight Float                       @default(0.4)
  deletedAt              DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  groups                 Group[]
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionCareers     InstitutionCareer[]
  optionalCourses        InstitutionOptionalCourse[]
  students               Student[]
  teachers               Teacher[]
}

model InstitutionCareer {
  id            String      @id @default(cuid())
  institutionId String
  careerId      String
  createdAt     DateTime    @default(now())
  applicants    Applicant[]
  career        Career      @relation(fields: [careerId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, careerId])
  @@index([careerId])
}

model InstitutionOptionalCourse {
  id            String      @id @default(cuid())
  institutionId String
  courseId      String
  createdAt     DateTime    @default(now())
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, courseId])
}

model Career {
  id                 String              @id @default(cuid())
  name               String
  code               String              @unique
  description        String?
  totalSemesters     Int                 @default(8)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  courses            Course[]
  groups             Group[]
  institutionCareers InstitutionCareer[]
  students           Student[]
}

model Course {
  id                   String                      @id @default(cuid())
  name                 String
  code                 String                      @unique
  description          String?
  credits              Float
  hours                Int
  courseType           CourseType                  @default(EXCLUSIVE)
  evaluationCount      Int                         @default(3)
  minUnits             Int                         @default(2)
  careerId             String?
  semester             Int?
  deletedAt            DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  academicHistories    AcademicHistory[]           @relation("CourseHistory")
  career               Career?                     @relation(fields: [careerId], references: [id])
  prerequisites        CoursePrerequisite[]        @relation("CourseMain")
  prerequisiteFor      CoursePrerequisite[]        @relation("CoursePrereq")
  enrollments          Enrollment[]                @relation("CourseEnrollments")
  groupCourses         GroupCourse[]
  institutionOptionals InstitutionOptionalCourse[]
  teacherGroups        TeacherGroup[]
  units                Unit[]                      @relation("CourseUnits")

  @@index([careerId, semester])
  @@index([courseType])
}

model Unit {
  id          String       @id @default(cuid())
  name        String
  unitNumber  Int
  description String?
  weight      Float        @default(1.0)
  lockedAt    DateTime?
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  course      Course       @relation("CourseUnits", fields: [courseId], references: [id], onDelete: Cascade)
  unitGrades  UnitGrade[]

  @@unique([courseId, unitNumber])
  @@index([courseId])
}

model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("CourseMain", fields: [courseId], references: [id])
  prerequisite   Course @relation("CoursePrereq", fields: [prerequisiteId], references: [id])

  @@unique([courseId, prerequisiteId])
}

model SchoolYear {
  id                String             @id @default(cuid())
  name              String
  startDate         DateTime
  endDate           DateTime
  status            SchoolYearStatus   @default(PLANNED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  enrollments       Enrollment[]
  evaluationPeriods EvaluationPeriod[]
  groups            Group[]
  promotionRecords  PromotionRecord[]

  @@index([status])
}

model EvaluationPeriod {
  id               String                     @id @default(cuid())
  schoolYearId     String
  name             String
  evaluationNumber Int
  isExtraordinary  Boolean                    @default(false)
  status           EvaluationPeriodStatus     @default(SCHEDULED)
  openDate         DateTime?
  closeDate        DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  schoolYear       SchoolYear                 @relation(fields: [schoolYearId], references: [id])
  auditLogs        EvaluationPeriodAuditLog[]
  unitGrades       UnitGrade[]

  @@unique([schoolYearId, evaluationNumber, isExtraordinary])
  @@index([schoolYearId, status])
}

model EvaluationPeriodAuditLog {
  id                 String                 @id @default(cuid())
  evaluationPeriodId String
  modifiedById       String
  previousStatus     EvaluationPeriodStatus
  newStatus          EvaluationPeriodStatus
  reason             String?
  createdAt          DateTime               @default(now())
  evaluationPeriod   EvaluationPeriod       @relation(fields: [evaluationPeriodId], references: [id], onDelete: Cascade)

  @@index([evaluationPeriodId])
  @@index([modifiedById])
  @@index([createdAt])
}

model Applicant {
  id                  String            @id @default(cuid())
  name                String
  lastName            String
  email               String
  curp                String            @unique
  age                 Int
  phone               String?
  state               String
  municipality        String
  neighborhood        String
  street              String
  number              String
  institutionCareerId String
  status              ApplicantStatus   @default(PENDING)
  studentId           String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  institutionCareer   InstitutionCareer @relation(fields: [institutionCareerId], references: [id])
  student             Student?          @relation(fields: [studentId], references: [id])

  @@index([institutionCareerId, status])
}

model Student {
  id                String            @id @default(cuid())
  enrollmentId      String            @unique
  curp              String            @unique
  birthDay          DateTime
  status            StudentStatus     @default(REGULAR)
  phone             String?
  state             String?
  municipality      String?
  neighborhood      String?
  street            String?
  number            String?
  userId            String            @unique
  institutionId     String
  careerId          String?
  currentSemester   Int               @default(1)
  failedCourseCount Int               @default(0)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  academicHistory   AcademicHistory[]
  applicant         Applicant?
  enrollments       Enrollment[]
  promotionRecords  PromotionRecord[]
  career            Career?           @relation(fields: [careerId], references: [id])
  institution       Institution       @relation(fields: [institutionId], references: [id])
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentGroups     StudentGroup[]

  @@index([careerId])
  @@index([institutionId])
  @@index([currentSemester])
  @@index([status])
}

model Teacher {
  id                    String         @id @default(cuid())
  employeeId            String         @unique
  department            String
  status                TeacherStatus  @default(ACTIVE)
  userId                String         @unique
  institutionId         String
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  registeredAttendances Attendance[]   @relation("RegisteredByTeacher")
  institution           Institution    @relation(fields: [institutionId], references: [id])
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherGroups         TeacherGroup[]
  assignedUnitGrades    UnitGrade[]    @relation("AssignedByTeacher")

  @@index([institutionId])
  @@index([status])
}

model Group {
  id                    String                 @id @default(cuid())
  name                  String
  groupType             GroupType
  semester              Int?
  careerId              String?
  institutionId         String
  schoolYearId          String
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  enrollments           Enrollment[]
  enrollmentRequirement EnrollmentRequirement?
  career                Career?                @relation(fields: [careerId], references: [id])
  institution           Institution            @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  schoolYear            SchoolYear             @relation(fields: [schoolYearId], references: [id])
  groupCourses          GroupCourse[]
  studentGroups         StudentGroup[]
  teacherGroups         TeacherGroup[]

  @@unique([institutionId, name, schoolYearId])
  @@index([institutionId])
  @@index([careerId])
  @@index([groupType])
  @@index([schoolYearId])
}

model GroupCourse {
  id        String   @id @default(cuid())
  groupId   String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, courseId])
  @@index([groupId])
  @@index([courseId])
}

model EnrollmentRequirement {
  id              String    @id @default(cuid())
  groupId         String    @unique
  minSemester     Int?
  careerId        String?
  maxCapacity     Int?
  enrollmentStart DateTime?
  enrollmentEnd   DateTime?
  isOpen          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  group           Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model StudentGroup {
  id        String   @id @default(cuid())
  studentId String
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, groupId])
  @@index([studentId])
  @@index([groupId])
}

model TeacherGroup {
  id        String   @id @default(cuid())
  teacherId String
  groupId   String
  courseId  String?
  role      String   @default("TITULAR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, groupId, courseId])
  @@index([teacherId])
  @@index([groupId])
  @@index([courseId])
}

model Enrollment {
  id                    String           @id @default(cuid())
  studentId             String
  courseId              String
  groupId               String?
  schoolYearId          String
  status                EnrollmentStatus @default(ENROLLED)
  globalEvaluationGrade Float?
  unitsAverage          Float?
  finalGrade            Float?
  deletedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  attendances           Attendance[]
  course                Course           @relation("CourseEnrollments", fields: [courseId], references: [id], onDelete: Cascade)
  group                 Group?           @relation(fields: [groupId], references: [id])
  schoolYear            SchoolYear       @relation(fields: [schoolYearId], references: [id])
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unitGrades            UnitGrade[]

  @@unique([studentId, courseId, schoolYearId])
  @@index([studentId])
  @@index([courseId])
  @@index([groupId])
  @@index([status])
  @@index([schoolYearId])
}

model UnitGrade {
  id                 String              @id @default(cuid())
  enrollmentId       String
  unitId             String
  evaluationPeriodId String?
  grade              Float?
  gradeType          GradeType           @default(ORDINARY)
  assignedById       String?
  comments           String?
  version            Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignedBy         Teacher?            @relation("AssignedByTeacher", fields: [assignedById], references: [id])
  enrollment         Enrollment          @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluationPeriod   EvaluationPeriod?   @relation(fields: [evaluationPeriodId], references: [id])
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  auditLogs          UnitGradeAuditLog[]

  @@unique([enrollmentId, unitId, gradeType])
  @@index([enrollmentId])
  @@index([unitId])
  @@index([evaluationPeriodId])
  @@index([assignedById])
  @@index([gradeType])
}

model UnitGradeAuditLog {
  id          String    @id @default(cuid())
  unitGradeId String
  oldGrade    Float?
  newGrade    Float?
  userId      String?
  reason      String?
  createdAt   DateTime  @default(now())
  unitGrade   UnitGrade @relation(fields: [unitGradeId], references: [id], onDelete: Cascade)

  @@index([unitGradeId])
  @@index([userId])
  @@index([createdAt])
}

model Attendance {
  id             String     @id @default(cuid())
  enrollmentId   String
  unitId         String
  sessionDate    DateTime
  present        Boolean    @default(false)
  justified      Boolean    @default(false)
  registeredById String
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  registeredBy   Teacher    @relation("RegisteredByTeacher", fields: [registeredById], references: [id])
  unit           Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, unitId, sessionDate])
  @@index([enrollmentId])
  @@index([unitId])
  @@index([sessionDate])
  @@index([registeredById])
}

model AcademicHistory {
  id                    String           @id @default(cuid())
  studentId             String
  courseId              String
  courseName            String
  courseCode            String
  courseCredits         Float
  schoolYearName        String
  semester              Int
  finalGrade            Float
  passed                Boolean
  status                EnrollmentStatus
  wasExtraordinary      Boolean          @default(false)
  globalEvaluationGrade Float?
  unitsAverage          Float
  unitGradesDetail      Json?
  attendancePercentage  Float?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  course                Course           @relation("CourseHistory", fields: [courseId], references: [id])
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, schoolYearName])
  @@index([studentId])
  @@index([courseId])
  @@index([semester])
  @@index([passed])
}

model PromotionRecord {
  id            String          @id @default(cuid())
  studentId     String
  schoolYearId  String
  fromSemester  Int
  toSemester    Int?
  status        PromotionStatus
  failedCourses Int             @default(0)
  notes         String?
  createdAt     DateTime        @default(now())
  schoolYear    SchoolYear      @relation(fields: [schoolYearId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, schoolYearId])
  @@index([studentId])
  @@index([schoolYearId])
}

model SystemAuditLog {
  id            String   @id @default(cuid())
  userId        String
  institutionId String?
  action        String
  entityType    String
  entityId      String
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([institutionId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum UserRole {
  ADMIN
  INSTITUTION
  TEACHER
  STUDENT
}

enum GroupType {
  CAREER_SEMESTER
  WORKSHOP
  INDIVIDUAL
}

enum CourseType {
  EXCLUSIVE
  FREE
}

enum EnrollmentStatus {
  ENROLLED
  PASSED
  FAILED
}

enum StudentStatus {
  REGULAR
  FAILED
  DROPOUT
  TEMPORARY_LEAVE
  GRADUATED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
}

enum ApplicantStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SchoolYearStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum EvaluationPeriodStatus {
  SCHEDULED
  OPEN
  CLOSED
}

enum GradeType {
  ORDINARY
  EXTRAORDINARY
}

enum PromotionStatus {
  PROMOTED
  PROMOTED_WITH_DEBT
  RETAINED
  PENDING
}
